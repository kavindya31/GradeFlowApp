<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F3F4F6">

    <!-- TOP BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#0A3BB0" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Change Password"
            android:textColor="#0A3BB0"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Profile avatar on right -->
        <ImageView
            android:id="@+id/imgTopAvatar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/img"
            android:background="@drawable/circle_outline_bg"/>
    </LinearLayout>

    <!-- SCROLL CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- MAIN SECURITY CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Update Security"
                        android:textColor="#111827"
                        android:textSize="26sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Ensure your account stays protected with a strong, unique password."
                        android:textColor="#4B5563"
                        android:textSize="14sp"/>

                    <!-- CURRENT PASSWORD -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:text="CURRENT PASSWORD"
                        android:textColor="#374151"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"/>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/input_field_bg"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">

                        <EditText
                            android:id="@+id/etCurrentPassword"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_toStartOf="@+id/btnToggleCurrentPassword"
                            android:background="@android:color/transparent"
                            android:hint="••••••••"
                            android:inputType="textPassword"
                            android:textColor="#111827"
                            android:textSize="15sp"/>

                        <ImageView
                            android:id="@+id/btnToggleCurrentPassword"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_password_eye"
                            android:padding="6dp"
                            app:tint="#6B7280"
                            android:background="?attr/selectableItemBackgroundBorderless"/>
                    </RelativeLayout>

                    <!-- NEW PASSWORD -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="NEW PASSWORD"
                        android:textColor="#374151"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"/>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/input_field_bg"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">

                        <EditText
                            android:id="@+id/etNewPassword"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_toStartOf="@+id/btnToggleNewPassword"
                            android:background="@android:color/transparent"
                            android:hint="••••••••"
                            android:inputType="textPassword"
                            android:textColor="#111827"
                            android:textSize="15sp"/>

                        <ImageView
                            android:id="@+id/btnToggleNewPassword"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_password_eye"
                            android:padding="6dp"
                            app:tint="#6B7280"
                            android:background="?attr/selectableItemBackgroundBorderless"/>
                    </RelativeLayout>

                    <!-- STRENGTH INDICATOR -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="10dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="4dp"
                            android:orientation="horizontal"
                            android:weightSum="4">

                            <View
                                android:id="@+id/strengthSegment1"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:layout_marginEnd="4dp"
                                android:background="#CBD5E1"/>

                            <View
                                android:id="@+id/strengthSegment2"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:layout_marginEnd="4dp"
                                android:layout_marginStart="4dp"
                                android:background="#CBD5E1"/>

                            <View
                                android:id="@+id/strengthSegment3"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:layout_marginEnd="4dp"
                                android:layout_marginStart="4dp"
                                android:background="#CBD5E1"/>

                            <View
                                android:id="@+id/strengthSegment4"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:layout_marginStart="4dp"
                                android:background="#CBD5E1"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Strong passwords include numbers and symbols."
                            android:textColor="#6B7280"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <!-- CONFIRM NEW PASSWORD -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="CONFIRM NEW PASSWORD"
                        android:textColor="#374151"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"/>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/input_field_bg"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">

                        <EditText
                            android:id="@+id/etConfirmPassword"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_toStartOf="@+id/btnToggleConfirmPassword"
                            android:background="@android:color/transparent"
                            android:hint="••••••••"
                            android:inputType="textPassword"
                            android:textColor="#111827"
                            android:textSize="15sp"/>

                        <ImageView
                            android:id="@+id/btnToggleConfirmPassword"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_password_eye"
                            android:padding="6dp"
                            app:tint="#6B7280"
                            android:background="?attr/selectableItemBackgroundBorderless"/>
                    </RelativeLayout>

                    <!-- UPDATE PASSWORD BUTTON -->
                    <Button
                        android:id="@+id/btnUpdatePassword"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="32dp"
                        android:text="Update Password  ⟳"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:background="@drawable/btn_primary_rounded"
                        app:backgroundTint="#4F46E5"/>

                    <!-- CANCEL LINK -->
                    <TextView
                        android:id="@+id/tvCancelLink"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="20dp"
                        android:text="Cancel"
                        android:textColor="#1D4ED8"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:padding="8dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
