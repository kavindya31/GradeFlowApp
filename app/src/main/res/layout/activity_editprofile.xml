<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EFF1F5">

    <!-- Top App Bar -->
    <!-- COMMON TOP BAR -->
    <include layout="@layout/common_top_bar"
        android:layout_width="0dp"
        android:layout_height="60dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@+id/topBar"
        app:layout_constraintBottom_toTopOf="@+id/buttonsPanel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="24dp"
            android:paddingBottom="24dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <!-- Avatar Section -->

            <!-- Text Fields Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp">

                    <ImageView
                        android:id="@+id/imgEditAvatar"
                        android:layout_width="110dp"
                        android:layout_height="110dp"
                        android:background="@drawable/circle_avatar_bg"
                        android:scaleType="centerCrop"
                        android:src="@drawable/img" />

                    <ImageView
                        android:id="@+id/btnCameraOverlay"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:layout_gravity="bottom|end"
                        android:background="@drawable/circle_blue_bg"
                        android:padding="8dp"
                        android:src="@drawable/ic_camera"
                        app:tint="#FFFFFF" />

                </FrameLayout>

                <TextView
                    android:id="@+id/tvChangePhoto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.08"
                    android:text="CHANGE PHOTO"
                    android:textColor="#1D4ED8"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Full Name -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FULL NAME"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#374151"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="8dp" />

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#F3F4F6"
                        android:layout_marginBottom="18dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp">

                            <EditText
                                android:id="@+id/etFullName"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:text="Alex Johnson"
                                android:inputType="textPersonName"
                                android:background="@null"
                                android:textSize="15sp"
                                android:textColor="#111827" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                app:tint="#9CA3AF" />

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- University Name -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="UNIVERSITY NAME"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#374151"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="8dp" />

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#F3F4F6"
                        android:layout_marginBottom="18dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp">

                            <EditText
                                android:id="@+id/etUniversity"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:text="Stanford University"
                                android:inputType="textCapWords"
                                android:background="@null"
                                android:textSize="15sp"
                                android:textColor="#111827" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                app:tint="#9CA3AF" />

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Degree Name -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DEGREE NAME"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#374151"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="8dp" />

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#F3F4F6">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp">

                            <EditText
                                android:id="@+id/etDegree"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:text="B.S. in Data Science"
                                android:inputType="textCapWords"
                                android:background="@null"
                                android:textSize="15sp"
                                android:textColor="#111827" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                app:tint="#9CA3AF" />

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Year & GPA Cards Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <!-- Year Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardYear"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#FFFFFF"
                    android:layout_marginEnd="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:padding="18dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_marginBottom="6dp"
                            app:tint="#3730A3" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="YEAR"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="#6B7280"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvYear"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Junior"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#111827" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- GPA Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardGPA"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#FFFFFF"
                    android:layout_marginStart="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:padding="18dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"

                            android:layout_marginBottom="6dp"
                            app:tint="#3730A3" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="GPA"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="#6B7280"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvEditGPA"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3.92"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#111827" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>
    <!-- Bottom Buttons -->
    <LinearLayout
        android:id="@+id/buttonsPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#EFF1F5"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toTopOf="@+id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnSaveChanges"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Save Changes"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"
            android:background="@drawable/btn_save_gradient"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:id="@+id/tvCancel"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="CANCEL"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/btn_save_gradient"
            android:gravity="center"/>
    </LinearLayout>

    <!-- COMMON BOTTOM NAV -->
    <include layout="@layout/common_bottom_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
