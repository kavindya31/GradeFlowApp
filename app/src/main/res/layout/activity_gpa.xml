<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F8">

    <!-- TOP NAV BAR -->
    <!-- COMMON TOP BAR -->
    <include layout="@layout/common_top_bar" />

    <!-- SCROLL CONTENT -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@+id/topBar"
        app:layout_constraintBottom_toTopOf="@+id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- ===== CGPA CARD ===== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="18dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#1A52D4">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CURRENT CGPA"
                        android:textColor="#BFCFEE"
                        android:textSize="11sp"
                        android:letterSpacing="0.1"
                        android:textStyle="bold"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="bottom"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3.88"
                            android:textColor="#FFFFFF"
                            android:textSize="52sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" CGPA"
                            android:textColor="#BFCFEE"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:layout_gravity="bottom"
                            android:layout_marginBottom="10dp"/>

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:layout_marginTop="6dp"
                        android:text="+0.12 this semester"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/cgpa_badge_bg"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== CREDITS CARD ===== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#7B3FF8">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CREDITS PROGRESS"
                        android:textColor="#D8C4FF"
                        android:textSize="11sp"
                        android:letterSpacing="0.1"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="124 / 140"
                        android:textColor="#FFFFFF"
                        android:textSize="42sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp"/>

                    <ProgressBar
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_marginTop="14dp"
                        android:max="100"
                        android:progress="88"
                        android:progressTint="#FFFFFF"
                        android:progressBackgroundTint="#9B6FF8"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="88% complete"
                        android:textColor="#D8C4FF"
                        android:textSize="14sp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== NEW SEMESTER GPA CALCULATION ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="26dp"
                android:layout_marginBottom="14dp"
                android:text="New Semester GPA Calculation"
                android:textColor="#111111"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <!-- Year + Semester dropdowns -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Year"
                        android:textSize="12sp"
                        android:textColor="#888888"
                        android:layout_marginBottom="6dp"/>

                    <Spinner
                        android:id="@+id/spinnerYear"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/spinner_bg"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:entries="@array/year_options"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Semester"
                        android:textSize="12sp"
                        android:textColor="#888888"
                        android:layout_marginBottom="6dp"/>

                    <Spinner
                        android:id="@+id/spinnerSemester"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/spinner_bg"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:entries="@array/semester_options"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Subject table card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:id="@+id/subjectTableContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="6dp">

                    <!-- Table header row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2"
                            android:text="SUBJECT"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="#AAAAAA"
                            android:letterSpacing="0.08"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2"
                            android:text="GRADE"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="#AAAAAA"
                            android:letterSpacing="0.08"
                            android:gravity="center"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="CREDITS"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="#AAAAAA"
                            android:letterSpacing="0.08"
                            android:gravity="end"/>

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="#EEEEEE"
                        android:layout_marginBottom="14dp"/>

                    <!-- Subject row 1: Machine -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2"
                            android:text="Machine"
                            android:textSize="15sp"
                            android:textColor="#111111"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="2"
                            android:background="@drawable/grade_dropdown_bg"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="10dp"
                            android:paddingEnd="8dp"
                            android:layout_marginEnd="8dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="A (4.0)"
                                android:textSize="13sp"
                                android:textColor="#111111"/>

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@android:drawable/arrow_down_float"
                                app:tint="#555555" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:background="@drawable/grade_dropdown_bg"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="10dp"
                            android:paddingEnd="6dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="3"
                                android:textSize="13sp"
                                android:textColor="#111111"/>

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@android:drawable/arrow_down_float"
                                app:tint="#555555" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Subject row 2: Digital E -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2"
                            android:text="Digital E"
                            android:textSize="15sp"
                            android:textColor="#111111"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="2"
                            android:background="@drawable/grade_dropdown_bg"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="10dp"
                            android:paddingEnd="8dp"
                            android:layout_marginEnd="8dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="A- (3.7)"
                                android:textSize="13sp"
                                android:textColor="#111111"/>

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@android:drawable/arrow_down_float"
                                app:tint="#555555" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:background="@drawable/grade_dropdown_bg"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="10dp"
                            android:paddingEnd="6dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="2"
                                android:textSize="13sp"
                                android:textColor="#111111"/>

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@android:drawable/arrow_down_float"
                                 app:tint="#555555" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="#EEEEEE"
                        android:layout_marginBottom="14dp"/>

                    <!-- Add Subject row -->
                    <LinearLayout
                        android:id="@+id/tvAddSubject"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginBottom="6dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_input_add"
                            android:layout_marginEnd="6dp"
                            app:tint="#0038B8" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Add Subject"
                            android:textSize="14sp"
                            android:textColor="#0038B8"
                            android:textStyle="bold"/>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== CALCULATE GPA BUTTON ===== -->
            <Button
                android:id="@+id/btnCalculateGpa"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="18dp"
                android:text="⊞  Calculate GPA"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold"
                android:background="@drawable/btn_calculate_bg"/>

            <!-- ===== SEMESTER HISTORY ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="14dp"
                android:text="Semester History"
                android:textColor="#111111"
                android:textSize="22sp"
                android:textStyle="bold"/>

            <!-- History card 1: Year 1 Semester 2 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <!-- Book icon box -->
                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="📋"
                        android:textSize="22sp"
                        android:gravity="center"
                        android:background="@drawable/history_icon_bg"
                        android:layout_marginEnd="14dp"/>

                    <!-- Labels -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Year 1 Semester 2"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#111111"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="18 Credits Earned"
                            android:textSize="12sp"
                            android:textColor="#888888"/>

                    </LinearLayout>

                    <!-- GPA + edit -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="end">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@android:drawable/ic_menu_edit"
                            android:layout_gravity="end"
                            android:layout_marginBottom="4dp"
                            app:tint="#BBBBBB" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cumulative"
                            android:textSize="11sp"
                            android:textColor="#AAAAAA"
                            android:layout_gravity="end"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3.88"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="#0038B8"
                            android:layout_gravity="end"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="GPA"
                            android:textSize="11sp"
                            android:textColor="#AAAAAA"
                            android:layout_gravity="end"/>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- History card 2: Year 1 Semester 1 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="📋"
                        android:textSize="22sp"
                        android:gravity="center"
                        android:background="@drawable/history_icon_bg"
                        android:layout_marginEnd="14dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Year 1 Semester 1"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#111111"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="15 Credits Earned"
                            android:textSize="12sp"
                            android:textColor="#888888"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="end">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@android:drawable/ic_menu_edit"
                            android:layout_gravity="end"
                            android:layout_marginBottom="4dp"
                            app:tint="#BBBBBB" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cumulative 3.72"
                            android:textSize="11sp"
                            android:textColor="#AAAAAA"
                            android:layout_gravity="end"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3.72"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="#0038B8"
                            android:layout_gravity="end"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="GPA"
                            android:textSize="11sp"
                            android:textColor="#AAAAAA"
                            android:layout_gravity="end"/>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== CALCULATE CGPA BUTTON ===== -->
            <Button
                android:id="@+id/btnCalculateCgpa"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:text="⊞  Calculate CGPA"
                android:textColor="#0038B8"
                android:textSize="17sp"
                android:textStyle="bold"
                android:background="@drawable/btn_cgpa_outline_bg"/>

        </LinearLayout>
    </ScrollView>

    <!-- COMMON BOTTOM NAV -->
    <include layout="@layout/common_bottom_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>