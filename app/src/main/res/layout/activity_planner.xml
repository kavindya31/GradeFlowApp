<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F8">

    <!-- TOP NAV BAR -->
    <!-- COMMON TOP BAR -->
    <include layout="@layout/common_top_bar" />

    <!-- SCROLL CONTENT -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@+id/topBar"
        app:layout_constraintBottom_toTopOf="@+id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="22dp"
            android:paddingBottom="100dp">

            <!-- PAGE TITLE -->
            <TextView
                android:id="@+id/tvPageTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="Study Planner"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#111111"/>

            <!-- ======= CALENDAR CARD ======= -->
            <androidx.cardview.widget.CardView
                android:id="@+id/calendarCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Month / Year header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:id="@+id/tvMonthName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="October"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#111111"/>

                        <ImageView
                            android:id="@+id/ivPrevMonth"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@android:drawable/ic_media_previous"
                            android:padding="4dp"
                            android:layout_marginStart="8dp"
                            app:tint="#555555" />

                        <ImageView
                            android:id="@+id/ivNextMonth"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@android:drawable/ic_media_next"
                            android:padding="4dp"
                            app:tint="#555555" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1"/>

                        <TextView
                            android:id="@+id/tvYear"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2023"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#111111"/>

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@android:drawable/arrow_up_float"
                            android:layout_marginStart="4dp"
                            app:tint="#555555" />

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@android:drawable/arrow_down_float"
                            app:tint="#555555" />

                    </LinearLayout>

                    <!-- Day of week headers -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp">

                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="S" android:gravity="center" android:textSize="13sp" android:textColor="#AAAAAA"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="M" android:gravity="center" android:textSize="13sp" android:textColor="#AAAAAA"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="T" android:gravity="center" android:textSize="13sp" android:textColor="#AAAAAA"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="W" android:gravity="center" android:textSize="13sp" android:textColor="#AAAAAA"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="T" android:gravity="center" android:textSize="13sp" android:textColor="#AAAAAA"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="F" android:gravity="center" android:textSize="13sp" android:textColor="#AAAAAA"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="S" android:gravity="center" android:textSize="13sp" android:textColor="#AAAAAA"/>

                    </LinearLayout>

                    <!-- Week row 1: 24-25-26 (prev month gray) + 1-2-3-4 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="2dp">

                        <TextView android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="24" android:gravity="center" android:textSize="14sp" android:textColor="#CCCCCC"/>
                        <TextView android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="25" android:gravity="center" android:textSize="14sp" android:textColor="#CCCCCC"/>
                        <TextView android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="26" android:gravity="center" android:textSize="14sp" android:textColor="#CCCCCC"/>
                        <TextView android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="1"  android:gravity="center" android:textSize="14sp" android:textColor="#222222"/>
                        <TextView android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="2"  android:gravity="center" android:textSize="14sp" android:textColor="#222222"/>
                        <TextView android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="3"  android:gravity="center" android:textSize="14sp" android:textColor="#222222"/>
                        <TextView android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="4"  android:gravity="center" android:textSize="14sp" android:textColor="#222222"/>

                    </LinearLayout>

                    <!-- Week row 2: 5-6(selected)-7-8-9-10-11 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="2dp">

                        <TextView android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="5"  android:gravity="center" android:textSize="14sp" android:textColor="#222222"/>

                        <TextView
                            android:id="@+id/tvSelectedDate"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:text="6"
                            android:gravity="center"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:background="@drawable/circle_blue_solid_bg"/>

                        <TextView android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="7"  android:gravity="center" android:textSize="14sp" android:textColor="#222222"/>
                        <TextView android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="8"  android:gravity="center" android:textSize="14sp" android:textColor="#222222"/>
                        <TextView android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="9"  android:gravity="center" android:textSize="14sp" android:textColor="#222222"/>
                        <TextView android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="10" android:gravity="center" android:textSize="14sp" android:textColor="#222222"/>
                        <TextView android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="11" android:gravity="center" android:textSize="14sp" android:textColor="#222222"/>

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="14dp"
                        android:background="#EEEEEE"/>

                    <!-- Events label -->
                    <TextView
                        android:id="@+id/tvEventsLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EVENTS FOR OCT 6"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#888888"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="10dp"/>

                    <!-- Event 1: Macroeconomics -->
                    <LinearLayout
                        android:id="@+id/eventRow1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp"
                        android:gravity="center_vertical">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="52dp"
                            android:background="#0038B8"
                            android:layout_marginEnd="12dp"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:background="@drawable/event_item_bg"
                            android:orientation="vertical"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:gravity="center_vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="09:00"
                                    android:textSize="13sp"
                                    android:textColor="#555555"
                                    android:layout_marginEnd="16dp"/>

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Macroeconomics"
                                        android:textSize="15sp"
                                        android:textStyle="bold"
                                        android:textColor="#111111"/>

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Room 102"
                                        android:textSize="12sp"
                                        android:textColor="#888888"/>

                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Event 2: Organic Chemistry -->
                    <LinearLayout
                        android:id="@+id/eventRow2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="52dp"
                            android:background="#7B3FF8"
                            android:layout_marginEnd="12dp"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:background="@drawable/event_item_bg"
                            android:orientation="vertical"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:gravity="center_vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="11:00"
                                    android:textSize="13sp"
                                    android:textColor="#555555"
                                    android:layout_marginEnd="16dp"/>

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Organic Chemistry"
                                        android:textSize="15sp"
                                        android:textStyle="bold"
                                        android:textColor="#111111"/>

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Lab 4"
                                        android:textSize="12sp"
                                        android:textColor="#888888"/>

                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ======= TAB ROW ======= -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <TextView
                    android:id="@+id/tabToday"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Today"
                    android:gravity="center"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#0038B8"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="@drawable/tab_selected_bg"/>

                <TextView
                    android:id="@+id/tabThisWeek"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="This Week"
                    android:gravity="center"
                    android:textSize="14sp"
                    android:textColor="#555555"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginStart="6dp"/>

                <TextView
                    android:id="@+id/tabThisMonth"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="This Month"
                    android:gravity="center"
                    android:textSize="14sp"
                    android:textColor="#555555"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginStart="6dp"/>

            </LinearLayout>

            <!-- ======= QUICK ADD CHIPS ======= -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="18dp">

                <TextView
                    android:id="@+id/chipExam"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="+ Exam"
                    android:gravity="center"
                    android:textSize="13sp"
                    android:textColor="#444444"
                    android:background="@drawable/chip_outline_bg"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/chipAssignment"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="+ Assignment"
                    android:gravity="center"
                    android:textSize="13sp"
                    android:textColor="#444444"
                    android:background="@drawable/chip_outline_bg"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/chipMidterm"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="+ Mid-term"
                    android:gravity="center"
                    android:textSize="13sp"
                    android:textColor="#444444"
                    android:background="@drawable/chip_outline_bg"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"/>

            </LinearLayout>

            <!-- ======= UPCOMING DEADLINES CARD ======= -->
            <androidx.cardview.widget.CardView
                android:id="@+id/deadlinesCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Header row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Upcoming Deadlines"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#111111"/>

                        <TextView
                            android:id="@+id/tvFilter"
                            android:layout_width="wrap_content"
                            android:layout_height="34dp"
                            android:text="≡  Filter"
                            android:gravity="center"
                            android:textSize="13sp"
                            android:textColor="#444444"
                            android:background="@drawable/chip_outline_bg"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"/>

                    </LinearLayout>

                    <!-- View All link -->
                    <TextView
                        android:id="@+id/tvViewAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VIEW ALL"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#0038B8"
                        android:letterSpacing="0.06"
                        android:layout_marginBottom="16dp"/>

                    <!-- Deadline item 1: Adv. Calculus Mid-Exam -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <CheckBox
                            android:id="@+id/checkDeadline1"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_marginEnd="12dp"
                            android:button="@drawable/checkbox_custom"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Adv. Calculus Mid-Exam"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="#111111"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Oct 9, 2023 • 10:00 AM"
                                android:textSize="12sp"
                                android:textColor="#888888"/>

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MID-EXAM"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="#E53935"
                            android:background="@drawable/badge_midexam_bg"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"/>

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="#EEEEEE"
                        android:layout_marginBottom="16dp"/>

                    <!-- Deadline item 2: History Presentation -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <CheckBox
                            android:id="@+id/checkDeadline2"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_marginEnd="12dp"
                            android:button="@drawable/checkbox_custom"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="History Presentation"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="#111111"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Oct 11, 2023 • 02:00 PM"
                                android:textSize="12sp"
                                android:textColor="#888888"/>

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PRESENTATION"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="#0038B8"
                            android:background="@drawable/badge_presentation_bg"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"/>

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="#EEEEEE"
                        android:layout_marginBottom="16dp"/>

                    <!-- Deadline item 3: AI Ethics Research Paper -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <CheckBox
                            android:id="@+id/checkDeadline3"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_marginEnd="12dp"
                            android:button="@drawable/checkbox_custom"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="AI Ethics Research Paper"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="#111111"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Oct 15, 2023 • 11:59 PM"
                                android:textSize="12sp"
                                android:textColor="#888888"/>

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RESEARCH"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:background="@drawable/badge_research_bg"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"/>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAdd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@android:drawable/ic_input_add"
        android:tint="#FFFFFF"
        app:backgroundTint="#0038B8"
        app:borderWidth="0dp"
        app:fabSize="normal"
        app:layout_constraintBottom_toTopOf="@+id/bottomNav"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"/>

    <!-- COMMON BOTTOM NAV -->
    <include layout="@layout/common_bottom_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>