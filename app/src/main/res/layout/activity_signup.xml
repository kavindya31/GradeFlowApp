<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EFF1F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="32dp"
        android:paddingBottom="32dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <!-- Logo at top -->
        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/logo"
            android:scaleType="fitCenter"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp" />

        <!-- Card containing form -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="28dp"
                android:paddingBottom="24dp">

                <!-- Create Account Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Create Account"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#111827"
                    android:layout_marginBottom="8dp" />

                <!-- Subtitle -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enter your details to start your high-performance semester."
                    android:textSize="14sp"
                    android:textColor="#6B7280"
                    android:layout_marginBottom="24dp" />

                <!-- Full Name Label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Full Name"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#374151"
                    android:layout_marginBottom="8dp" />

                <!-- Full Name Input -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#F3F4F6"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="18dp"
                            android:layout_marginEnd="12dp"
                            app:tint="#9CA3AF" />

                        <EditText
                            android:id="@+id/etFullName"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:hint="Alex Johnson"
                            android:inputType="textPersonName"
                            android:background="@null"
                            android:textSize="14sp"
                            android:textColor="#111827"
                            android:textColorHint="#9CA3AF" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- University Name Label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="University Name"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#374151"
                    android:layout_marginBottom="8dp" />

                <!-- University Input -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#F3F4F6"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/school"
                            android:layout_marginEnd="12dp"
                            app:tint="#9CA3AF" />

                        <EditText
                            android:id="@+id/etUniversity"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:hint="Stanford University"
                            android:inputType="textCapWords"
                            android:background="@null"
                            android:textSize="14sp"
                            android:textColor="#111827"
                            android:textColorHint="#9CA3AF" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Email Label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#374151"
                    android:layout_marginBottom="8dp" />

                <!-- Email Input -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#F3F4F6"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/emails"
                            android:layout_marginEnd="12dp"
                            app:tint="#9CA3AF" />

                        <EditText
                            android:id="@+id/etEmail"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:hint="alex@email.com"
                            android:inputType="textEmailAddress"
                            android:background="@null"
                            android:textSize="14sp"
                            android:textColor="#111827"
                            android:textColorHint="#9CA3AF" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Password Label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Password"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#374151"
                    android:layout_marginBottom="8dp" />

                <!-- Password Input -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#F3F4F6"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/shield"
                            android:layout_marginEnd="12dp"
                            app:tint="#9CA3AF" />

                        <EditText
                            android:id="@+id/etPassword"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:hint="••••••••"
                            android:inputType="textPassword"
                            android:background="@null"
                            android:textSize="14sp"
                            android:textColor="#111827"
                            android:textColorHint="#9CA3AF" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Confirm Password Label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Confirm Password"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#374151"
                    android:layout_marginBottom="8dp" />

                <!-- Confirm Password Input -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#F3F4F6"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/shield"
                            android:layout_marginEnd="12dp"
                            app:tint="#9CA3AF" />

                        <EditText
                            android:id="@+id/etConfirmPassword"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:hint="••••••••"
                            android:inputType="textPassword"
                            android:background="@null"
                            android:textSize="14sp"
                            android:textColor="#111827"
                            android:textColorHint="#9CA3AF" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Terms Checkbox -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="24dp">

                    <CheckBox
                        android:id="@+id/cbTerms"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="#1D4ED8"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="#374151">
                        <!-- Use SpannableString in Java for clickable links -->
                    </TextView>

                    <!-- Terms text split for clickable spans in Java -->
                    <TextView
                        android:id="@+id/tvTerms"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="I agree to the Terms of Service and Privacy Policy."
                        android:textSize="13sp"
                        android:textColor="#374151" />

                </LinearLayout>

                <!-- Create Account Button -->
                <Button
                    android:id="@+id/btnCreateAccount"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Create Account  →"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:background="@drawable/btn_primary"
                    android:layout_marginBottom="20dp" />

                <!-- Login Link -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_gravity="center_horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Already have an account? "
                        android:textSize="14sp"
                        android:textColor="#6B7280" />

                    <TextView
                        android:id="@+id/tvLogin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Log in here"
                        android:textSize="14sp"
                        android:textColor="#1D4ED8"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Footer -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="© 2024 GradeFlow AI Academic Systems"
            android:textSize="12sp"
            android:textColor="#9CA3AF"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp" />

    </LinearLayout>
</ScrollView>